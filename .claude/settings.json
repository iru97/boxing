{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "Bash",
      "Agent",
      "Skill",
      "WebSearch",
      "WebFetch",
      "NotebookEdit"
    ],
    "deny": []
  },
  "model": "opus",
  "agentTeams": {
    "enabled": true,
    "maxTeamSize": 5,
    "requirePlanApproval": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/reinject-context.sh",
            "timeout": 10,
            "statusMessage": "Reinjecting project context after compaction..."
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/reinject-context.sh",
            "timeout": 10,
            "statusMessage": "Loading project context for resumed session..."
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/reinject-context.sh",
            "timeout": 10,
            "statusMessage": "Loading project context..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/save-state-pre-compact.sh",
            "timeout": 5,
            "statusMessage": "Saving sprint state before compaction..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/reinject-context.sh",
            "timeout": 10,
            "statusMessage": "Restoring project context after compaction..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-check.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Check: no secrets, follow FLUTTER_ARCHITECTURE.md patterns, run flutter analyze after'",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
