{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "Bash",
      "Agent",
      "Skill",
      "WebSearch",
      "WebFetch",
      "NotebookEdit"
    ],
    "deny": []
  },
  "model": "opus",
  "agentTeams": {
    "enabled": true,
    "maxTeamSize": 5,
    "requirePlanApproval": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Verify: no secrets, timer logic UI-independent, audio pre-loaded'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '--- Session ended. Run: flutter analyze && flutter test ---'"
          }
        ]
      }
    ]
  }
}
